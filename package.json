{
  "name": "fitzoneprо-whatsapp-agent",
  "version": "1.0.0",
  "description": "WhatsApp AI agent for FitZone Pro gym ",
  "main": "src/index.js",
  "scripts": {
    "start"    : "node src/index.js",
    "dev"      : "nodemon src/index.js",
